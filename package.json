{
  "name": "basic-package-template",
  "version": "0.0.0-development",
  "packageManager": "pnpm@9.15.4",
  "description": "Package description",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "echo \"Add your build setup (e.g. tsup, tsc)\"",
    "bootstrap": "./scripts/bootstrap.sh",
    "setup:branch-protection": "./scripts/setup-branch-protection.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xtiby/basic-package-template.git"
  },
  "keywords": [],
  "author": "0xtiby <https://github.com/0xtiby>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/0xtiby/basic-package-template/issues"
  },
  "homepage": "https://github.com/0xtiby/basic-package-template#readme",
  "devDependencies": {
    "@semantic-release/github": "^12.0.2",
    "semantic-release": "^25.0.2"
  }
}
